# =============================================================================
# Dive Service Management - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment.
# The setup script (scripts/setup.sh) will do this automatically.
#
# All application-specific variables are prefixed with DSM_ for namespacing.
# MariaDB variables use the MARIADB_ prefix expected by the official image.
# =============================================================================

# ---------------------------------------------------------------------------
# Flask Application
# ---------------------------------------------------------------------------

# Flask secret key for session signing and CSRF protection.
# REQUIRED - Generate with: python scripts/generate_secret_key.py
DSM_SECRET_KEY=change-me-to-a-random-secret

# Password salt for Flask-Security-Too.
# REQUIRED - Generate with: python scripts/generate_secret_key.py
DSM_SECURITY_PASSWORD_SALT=change-me-to-a-random-salt

# Application environment: development, production, testing
# (DSM_ENV takes precedence over FLASK_ENV which is deprecated)
DSM_ENV=production

# Enable debug mode (true/false). NEVER enable in production.
DSM_DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DSM_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Network / Server
# ---------------------------------------------------------------------------

# Port the application listens on (host-side Docker port mapping)
DSM_PORT=8080

# Network interface to bind to (0.0.0.0 = all interfaces)
DSM_BIND_ADDRESS=0.0.0.0

# Gunicorn worker count (2 is good for Pi, increase for x86-64 servers)
DSM_WORKERS=2

# Gunicorn threads per worker
DSM_THREADS=4

# ---------------------------------------------------------------------------
# Database (MariaDB)
# ---------------------------------------------------------------------------

# Full SQLAlchemy database URI.
# Default points to the Docker Compose 'db' service.
DSM_DATABASE_URL=mysql+mysqldb://dsm:dsm@db:3306/dsm

# MariaDB root password (used by the mariadb Docker image on first start)
# REQUIRED - The setup script generates a random value automatically.
MARIADB_ROOT_PASSWORD=change-me-root-password

# MariaDB database name, user, and password for the application.
# These must match the credentials in DSM_DATABASE_URL above.
MARIADB_DATABASE=dsm
MARIADB_USER=dsm
MARIADB_PASSWORD=change-me-db-password

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

# Redis connection URL (used for caching, sessions, and task queue broker)
DSM_REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Celery Task Queue (full deployment)
# ---------------------------------------------------------------------------

# Celery broker URL (Redis database 1)
DSM_CELERY_BROKER_URL=redis://redis:6379/1

# Celery result backend (Redis database 2)
DSM_CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------------------------------------------------------------------------
# File Uploads
# ---------------------------------------------------------------------------

# Directory for uploaded files (inside the container)
DSM_UPLOAD_FOLDER=/app/uploads

# Maximum upload file size in bytes (default: 16MB)
DSM_MAX_CONTENT_LENGTH=16777216

# ---------------------------------------------------------------------------
# Deployment Profile
# ---------------------------------------------------------------------------
# Set to "lightweight" to use Huey instead of Celery (for Raspberry Pi).
# Leave empty or set to "full" for standard Celery deployment.
DSM_DEPLOYMENT_PROFILE=full

# ---------------------------------------------------------------------------
# Cloud Deployment (optional)
# ---------------------------------------------------------------------------

# Force HTTPS redirect (set to true behind a TLS-terminating load balancer)
# DSM_FORCE_HTTPS=false

# Comma-separated list of allowed Host headers (security against host header attacks)
# DSM_ALLOWED_HOSTS=*

# Comma-separated trusted proxy IPs for X-Forwarded-For header processing
# DSM_TRUSTED_PROXIES=
