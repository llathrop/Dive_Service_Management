# =============================================================================
# Dive Service Management - Persistent Test Runner Dockerfile
# Stays running so you can exec into it for rapid test execution.
# Source code is mounted as volumes, not copied — changes are instant.
#
# Build:  docker compose -f docker-compose.test-dev.yml build
# Start:  docker compose -f docker-compose.test-dev.yml up -d
# Test:   docker compose -f docker-compose.test-dev.yml exec test pytest
# =============================================================================

FROM python:3.12-slim

WORKDIR /app

# Minimal system dependencies (no MySQL client needed for SQLite testing)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libffi-dev \
    build-essential \
    pkg-config \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install production Python dependencies (excluding mysqlclient)
COPY requirements.txt .
RUN grep -v mysqlclient requirements.txt > /tmp/requirements-filtered.txt \
    && pip install --no-cache-dir -r /tmp/requirements-filtered.txt \
    && rm /tmp/requirements-filtered.txt

# Install test-only dependencies
COPY requirements-test.txt .
RUN pip install --no-cache-dir -r requirements-test.txt

# Source code is mounted as a volume at runtime, not copied.
# This keeps the container reusable across code changes.

# Default command keeps the container running for exec-based test runs
CMD ["sleep", "infinity"]
